# arxiv-daily 配置文件模板
# 复制为 config.yaml 并修改以覆盖默认值

arxiv:
  keywords:
    - "portrait generation"
    - "image-to-image"
    - "text-to-image"
  max_results_per_keyword: 50
  days_back: 1
  categories: ["cs.CV", "cs.AI", "cs.LG"]

feishu:
  webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN"  # 请替换为你的飞书机器人 webhook 地址
  web_url: "YOUR_IP_ADDRESS"  # 请替换为你的本机 IP 地址

translate:
  api: "free"  # "free" 用 deep-translator, "openai" 用 OpenAI API
  openai_api_key: ""  # 如果使用 OpenAI，请填入你的 API Key
  openai_base_url: "https://api.openai.com/v1"
  openai_model: "gpt-4o-mini"

local:
  data_dir: "./data"
  pdf_dir: "./pdfs"
